{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "workspace-hub",
  "version": "0.1.0",
  "identifier": "dev.hsryuuu.workspace-hub",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3003",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  },
  "app": {
    "windows": [
      {
        "title": "workspace-hub",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
